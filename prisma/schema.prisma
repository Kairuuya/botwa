model User {
  jid               String             @id
  lid               String?
  pushName          String
  role              UserRole           @default(FREE)
  expiredAt         DateTime?
  limit             Int                @default(0)
  language          String             @default("id")
  isBanned          Boolean            @default(false)
  isBlock           Boolean            @default(false)
  isMute            Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  groupParticipants GroupParticipant[]

  @@index([jid])
  @@map("users")
}

model Group {
  jid        String   @id
  welcome    String?  @default("")
  goodbye    String?  @default("")
  isAntiLink Boolean  @default(false)
  isAntiBot  Boolean  @default(false)
  isBanned   Boolean  @default(false)
  isMute     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  // settings     GroupSetting
  metadata     GroupMetadata?
  participants GroupParticipant[]

  @@map("groups")
}

/// Stores the WhatsApp group metadata (1:1 with Group)
model GroupMetadata {
  id                  String  @id
  addressingMode      String?
  subject             String
  subjectOwner        String?
  subjectOwnerPn      String?
  subjectTime         Int?
  size                Int     @default(0)
  creation            Int?
  owner               String  @default("")
  ownerPn             String?
  ownerCountryCode    String?
  desc                String?
  descId              String?
  descOwner           String?
  descOwnerPn         String?
  descTime            Int?
  restrict            Boolean @default(false)
  announce            Boolean @default(false)
  isCommunity         Boolean @default(false)
  isCommunityAnnounce Boolean @default(false)
  joinApprovalMode    Boolean @default(false)
  memberAddMode       Boolean @default(false)

  // Relations
  group Group @relation(fields: [id], references: [jid], onDelete: Cascade)

  @@map("group_metadata")
}

/// Individual participant entries within a group
model GroupParticipant {
  groupJid  String
  userJid   String // WhatsApp participant JID
  role      GroupRole @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Relations
  group     Group     @relation(fields: [groupJid], references: [jid], onDelete: Cascade)
  user      User      @relation(fields: [userJid], references: [jid], onDelete: Cascade)

  @@unique([groupJid, userJid])
  @@index([userJid])
  @@map("group_participants")
}

model Session {
  id        String   @id
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model rafs {
  id                        Int        @id  @default(autoincrement())
  production                String?    @map("Production")
  itemNumber                String?    @map("Item number")
  moduleid                  String?    @map("ModuleID")
  namaProduk                String?    @map("Nama Produk")
  picProcess                String?    @map("PIC Process")
  picPacking                String?    @map("PIC Packing")
  site                      String?    @map("Site")
  warehouse                 String?    @map("Warehouse")
  quantity                  Float?     @map("Quantity")
  started                   Float?     @map("Started")
  reportAsFinished          Float?     @map("Report as finished")
  tanggal                   DateTime?  @map("Tanggal")
  bomconsump                Float?     @map("BOMConsump")
  bomproposal               Float?     @map("BOMProposal")
  qtyAdjust                 Float?     @map("Qty Adjust")
  started2                  DateTime?  @map("Started2")
  ended                     DateTime?  @map("Ended")
  status                    String?    @map("Status")
  totalLoss                 Float?     @map("Total Loss")
  hours                     Float?     @map("Hours")
  manHours                  Float?     @map("Man Hours")
  resultViskositas          Float?     @map("Result Viskositas")
  resultSolidcontent        Float?     @map("Result SolidContent")
  resultPh                  Float?     @map("Result pH")
  pool                      String?    @map("Pool")
  mesin                     String?    @map("Mesin")
  productionType            String?    @map("Production Type")
  totalMaterialConsumption  Float?     @map("Total Material Consumption")
  bomNumber                 String?    @map("BOM number")
}
