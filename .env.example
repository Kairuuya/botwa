# Environment Configuration Example
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_URL="your_database_url"

# Redis Configuration (Optional / If used)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache Configuration
CACHE_DEFAULT_TTL_MS=300000
CACHE_MAX_SIZE=5000
CACHE_TYPE=auto
